{
  "name": "openknowledge-monorepo",
  "private": true,
  "version": "0.7.2",
  "license": "Apache-2.0",
  "scripts": {
    "dev:web": "pnpm --filter @openknowledge-sh/web dev",
    "build:web": "pnpm --filter @openknowledge-sh/web build",
    "test:cli": "go test ./packages/cli/...",
    "test:install": "bash scripts/test-install.sh",
    "test:npm-install": "node --test packages/npm/install.test.js",
    "test:web": "pnpm --filter @openknowledge-sh/web test",
    "build:cli": "go build -o bin/openknowledge ./packages/cli/cmd/openknowledge",
    "check:versions": "node scripts/check-versions.mjs",
    "check:workflow-pins": "node scripts/check-workflow-pins.mjs",
    "check:workflow-secret-scope": "node scripts/check-workflow-secret-scope.mjs",
    "check:workflow-permissions": "node scripts/check-workflow-permissions.mjs",
    "check:security-config": "node scripts/check-security-config.mjs",
    "check:container-runtime": "node scripts/check-container-runtime.mjs",
    "check:repo-jobs": "go run ./packages/cli/cmd/openknowledge jobs validate .openknowledge/jobs",
    "test": "pnpm check:versions && pnpm check:workflow-pins && pnpm check:workflow-secret-scope && pnpm check:workflow-permissions && pnpm check:security-config && pnpm check:container-runtime && pnpm check:repo-jobs && pnpm test:install && pnpm test:npm-install && pnpm test:web && pnpm test:cli",
    "build": "pnpm build:cli && pnpm build:web"
  }
}

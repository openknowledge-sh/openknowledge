{
  "name": "openknowledge-monorepo",
  "private": true,
  "version": "0.6.0",
  "license": "Apache-2.0",
  "scripts": {
    "dev:web": "pnpm --filter @openknowledge-sh/web dev",
    "build:web": "pnpm --filter @openknowledge-sh/web build",
    "test:cli": "go test ./packages/cli/...",
    "build:cli": "go build -o bin/openknowledge ./packages/cli/cmd/openknowledge",
    "check:versions": "node scripts/check-versions.mjs",
    "check:workflow-pins": "node scripts/check-workflow-pins.mjs",
    "test": "pnpm check:versions && pnpm check:workflow-pins && pnpm test:cli",
    "build": "pnpm build:cli && pnpm build:web"
  }
}

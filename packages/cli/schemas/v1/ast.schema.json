{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openknowledge.sh/schemas/cli/v1/ast.schema.json",
  "title": "Open Knowledge AST output v1",
  "type": "object",
  "required": ["schemaVersion", "root", "specVersion", "documents"],
  "properties": {
    "schemaVersion": {"const": "1"},
    "root": {"type": "string"},
    "specVersion": {"type": "string"},
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["absolute", "rel", "id", "kind", "frontmatter", "metadata", "markdown"],
        "properties": {
          "absolute": {"type": "string"},
          "rel": {"type": "string"},
          "id": {"type": "string"},
          "kind": {"type": "string"},
          "reserved": {"type": "boolean"},
          "content": {"type": "string"},
          "frontmatter": {
            "type": "object",
            "required": ["has", "bodyLine"],
            "properties": {
              "has": {"type": "boolean"},
              "values": {"type": "object", "additionalProperties": {"type": "string"}},
              "data": {"type": "object", "additionalProperties": {"$ref": "common.schema.json#/$defs/typedValue"}},
              "warnings": {"type": "array", "items": {"$ref": "#/$defs/frontmatterWarning"}},
              "bodyLine": {"type": "integer", "minimum": 1}
            },
            "additionalProperties": false
          },
          "metadata": {"$ref": "#/$defs/metadata"},
          "body": {"type": "string"},
          "markdown": {"$ref": "#/$defs/markdown"},
          "links": {"type": "array", "items": {"$ref": "common.schema.json#/$defs/link"}},
          "readDiagnostic": {"$ref": "#/$defs/diagnostic"},
          "utf8Diagnostic": {"$ref": "#/$defs/diagnostic"},
          "frontmatterDiagnostic": {"$ref": "#/$defs/diagnostic"}
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "frontmatterWarning": {
      "type": "object",
      "required": ["line", "message"],
      "properties": {
        "line": {"type": "integer", "minimum": 1},
        "message": {"type": "string"}
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "properties": {
        "type": {"type": "string"},
        "title": {"type": "string"},
        "description": {"type": "string"},
        "resource": {"type": "string"},
        "tags": {"type": "array", "items": {"type": "string"}},
        "useWhen": {"type": "array", "items": {"type": "string"}},
        "bundle": {"$ref": "#/$defs/bundleMetadata"}
      },
      "additionalProperties": false
    },
    "bundleMetadata": {
      "type": "object",
      "properties": {
        "name": {"type": "string"},
        "title": {"type": "string"},
        "purpose": {"type": "string"},
        "tags": {"type": "array", "items": {"type": "string"}},
        "entries": {"type": "array", "items": {"$ref": "#/$defs/bundleEntry"}}
      },
      "additionalProperties": false
    },
    "bundleEntry": {
      "type": "object",
      "required": ["name", "path"],
      "properties": {
        "name": {"type": "string"},
        "path": {"type": "string"}
      },
      "additionalProperties": false
    },
    "diagnostic": {
      "type": "object",
      "required": ["message"],
      "properties": {
        "line": {"type": "integer", "minimum": 1},
        "message": {"type": "string"}
      },
      "additionalProperties": false
    },
    "markdown": {
      "type": "object",
      "properties": {
        "blocks": {"type": "array", "items": {"$ref": "#/$defs/block"}},
        "sections": {"type": "array", "items": {"$ref": "#/$defs/section"}},
        "headings": {"type": "array", "items": {"$ref": "#/$defs/heading"}},
        "links": {"type": "array", "items": {"$ref": "#/$defs/markdownLink"}},
        "codeBlocks": {"type": "array", "items": {"$ref": "#/$defs/codeBlock"}},
        "diagnostics": {"type": "array", "items": {"$ref": "#/$defs/diagnostic"}}
      },
      "additionalProperties": false
    },
    "block": {
      "type": "object",
      "required": ["kind", "lineStart", "lineEnd"],
      "properties": {
        "kind": {"type": "string"},
        "lineStart": {"type": "integer", "minimum": 1},
        "lineEnd": {"type": "integer", "minimum": 1},
        "text": {"type": "string"},
        "heading": {"$ref": "#/$defs/heading"},
        "codeBlock": {"$ref": "#/$defs/codeBlock"},
        "list": {"$ref": "#/$defs/list"},
        "table": {"$ref": "#/$defs/table"},
        "links": {"type": "array", "items": {"$ref": "#/$defs/markdownLink"}},
        "children": {"type": "array", "items": {"$ref": "#/$defs/block"}}
      },
      "additionalProperties": false
    },
    "heading": {
      "type": "object",
      "required": ["level", "text", "anchor", "line"],
      "properties": {
        "level": {"type": "integer", "minimum": 1},
        "text": {"type": "string"},
        "anchor": {"type": "string"},
        "line": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "section": {
      "type": "object",
      "required": ["heading", "level", "anchor", "lineStart", "lineEnd"],
      "properties": {
        "heading": {"type": "string"},
        "level": {"type": "integer", "minimum": 1},
        "anchor": {"type": "string"},
        "lineStart": {"type": "integer", "minimum": 1},
        "lineEnd": {"type": "integer", "minimum": 1},
        "blocks": {"type": "array", "items": {"$ref": "#/$defs/block"}},
        "children": {"type": "array", "items": {"$ref": "#/$defs/section"}}
      },
      "additionalProperties": false
    },
    "markdownLink": {
      "type": "object",
      "required": ["label", "href", "kind", "line"],
      "properties": {
        "label": {"type": "string"},
        "href": {"type": "string"},
        "kind": {"type": "string"},
        "line": {"type": "integer", "minimum": 1},
        "image": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "codeBlock": {
      "type": "object",
      "required": ["lineStart", "lineEnd"],
      "properties": {
        "info": {"type": "string"},
        "language": {"type": "string"},
        "text": {"type": "string"},
        "lineStart": {"type": "integer", "minimum": 1},
        "lineEnd": {"type": "integer", "minimum": 1},
        "mermaid": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "list": {
      "type": "object",
      "required": ["items"],
      "properties": {
        "ordered": {"type": "boolean"},
        "items": {"type": "array", "items": {"$ref": "#/$defs/listItem"}}
      },
      "additionalProperties": false
    },
    "listItem": {
      "type": "object",
      "required": ["text", "lineStart", "lineEnd"],
      "properties": {
        "text": {"type": "string"},
        "lineStart": {"type": "integer", "minimum": 1},
        "lineEnd": {"type": "integer", "minimum": 1},
        "links": {"type": "array", "items": {"$ref": "#/$defs/markdownLink"}}
      },
      "additionalProperties": false
    },
    "table": {
      "type": "object",
      "required": ["header", "rows"],
      "properties": {
        "header": {"type": "array", "items": {"type": "string"}},
        "alignments": {"type": "array", "items": {"type": "string"}},
        "rows": {"type": "array", "items": {"$ref": "#/$defs/tableRow"}}
      },
      "additionalProperties": false
    },
    "tableRow": {
      "type": "object",
      "required": ["cells", "line"],
      "properties": {
        "cells": {"type": "array", "items": {"type": "string"}},
        "line": {"type": "integer", "minimum": 1},
        "links": {"type": "array", "items": {"$ref": "#/$defs/markdownLink"}}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openknowledge.sh/schemas/cli/v1/search-context.schema.json",
  "title": "Open Knowledge search context v1",
  "type": "object",
  "required": ["schemaVersion", "root", "revision", "query", "budget", "estimatedTokens", "limit", "sources", "issues"],
  "properties": {
    "schemaVersion": {"const": "1"},
    "root": {"type": "string"},
    "revision": {"$ref": "common.schema.json#/$defs/retrievalRevision"},
    "query": {"type": "string"},
    "budget": {"type": "integer", "minimum": 1},
    "estimatedTokens": {"type": "integer", "minimum": 0},
    "limit": {"type": "integer", "minimum": 1},
    "sources": {"type": "array", "items": {"$ref": "#/$defs/source"}},
    "issues": {"type": "array", "items": {"$ref": "common.schema.json#/$defs/issue"}}
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": ["id", "locator", "contentSha256", "path", "kind", "title", "heading", "lineStart", "lineEnd", "score", "estimatedTokens", "relation", "markdown"],
      "properties": {
        "id": {"type": "string"},
        "locator": {"type": "string", "pattern": "^okf\\+sha256://[a-f0-9]{64}/.+#[a-f0-9]{64}$"},
        "contentSha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "path": {"type": "string"},
        "kind": {"type": "string"},
        "type": {"type": "string"},
        "title": {"type": "string"},
        "heading": {"type": "string"},
        "headingPath": {"type": "array", "items": {"type": "string"}},
        "headingLevel": {"type": "integer", "minimum": 1},
        "lineStart": {"type": "integer", "minimum": 1},
        "lineEnd": {"type": "integer", "minimum": 1},
        "score": {"type": "number"},
        "estimatedTokens": {"type": "integer", "minimum": 0},
        "relation": {"enum": ["direct", "outgoing-link", "backlink"]},
        "markdown": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

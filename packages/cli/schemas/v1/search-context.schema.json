{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openknowledge.sh/schemas/cli/v1/search-context.schema.json",
  "title": "Open Knowledge search context v1",
  "type": "object",
  "required": ["schemaVersion", "root", "query", "budget", "estimatedTokens", "limit", "sources", "issues"],
  "properties": {
    "schemaVersion": {"const": "1"},
    "root": {"type": "string"},
    "query": {"type": "string"},
    "budget": {"type": "integer", "minimum": 1},
    "estimatedTokens": {"type": "integer", "minimum": 0},
    "limit": {"type": "integer", "minimum": 1},
    "sources": {"type": "array", "items": {"type": "object", "required": ["id", "path", "kind", "title", "heading", "lineStart", "lineEnd", "score", "estimatedTokens", "relation", "markdown"], "additionalProperties": true}},
    "issues": {"type": "array", "items": {"$ref": "common.schema.json#/$defs/issue"}}
  },
  "additionalProperties": false
}

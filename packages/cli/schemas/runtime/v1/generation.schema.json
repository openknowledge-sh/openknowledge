{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openknowledge.sh/schemas/cli/runtime/v1/generation.schema.json",
  "title": "Open Knowledge immutable generation manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "version", "knowledgeBaseId", "commit", "spec", "contentDigest", "files"],
  "properties": {
    "type": { "const": "openknowledge.generation" },
    "version": { "const": 1 },
    "knowledgeBaseId": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
    "commit": { "type": "string", "minLength": 1, "pattern": "^[^/\\\\]+$" },
    "spec": { "type": "string", "minLength": 1 },
    "contentDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "bytes"],
        "properties": {
          "path": { "type": "string", "pattern": "^(public|source|search|mcp)/" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "bytes": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
